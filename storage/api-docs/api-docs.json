{
    "openapi": "3.0.0",
    "info": {
        "title": "Team 12 - Account Management API",
        "description": "Comprehensive API for account management, transaction logging, and statement generation. Supports account CRUD operations, atomic balance updates, transaction history tracking, and statement export functionality.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/api/accounts": {
            "get": {
                "tags": [
                    "Accounts"
                ],
                "summary": "List accounts",
                "description": "Get paginated list of bank accounts.",
                "operationId": "1f1ea4d0ec24f55da316f8a01a4773e6",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Number of records per page.",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15,
                            "maximum": 100,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Accounts fetched successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedAccountsResponse"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Accounts"
                ],
                "summary": "Create account",
                "description": "Create a new customer bank account.",
                "operationId": "ab9a4fc50a7da5bcc14d51103505fa1d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateAccountRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Account created successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountMessageResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/accounts/{account}": {
            "get": {
                "tags": [
                    "Accounts"
                ],
                "summary": "Get account detail",
                "description": "Get account detail by account id.",
                "operationId": "e9a751de46d3030241bc5d81d06988c6",
                "parameters": [
                    {
                        "name": "account",
                        "in": "path",
                        "description": "Account id.",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Account detail fetched successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountDataResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Account not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "patch": {
                "tags": [
                    "Accounts"
                ],
                "summary": "Update account profile",
                "description": "Update account profile fields such as name, email, phone, and address.",
                "operationId": "91859f8ffc9f41d9a391d271d5a95f3a",
                "parameters": [
                    {
                        "name": "account",
                        "in": "path",
                        "description": "Account id.",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAccountRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Account updated successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountMessageResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Account not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/accounts/{account}/status": {
            "patch": {
                "tags": [
                    "Accounts"
                ],
                "summary": "Update account status",
                "description": "Update account status to active, inactive, or blocked.",
                "operationId": "862de7ec079fb167e09b25010ee1d2e0",
                "parameters": [
                    {
                        "name": "account",
                        "in": "path",
                        "description": "Account id.",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAccountStatusRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Account status updated successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountMessageResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Account not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/accounts/{account}/balance/adjust": {
            "post": {
                "tags": [
                    "Accounts"
                ],
                "summary": "Adjust account balance",
                "description": "Adjust account balance atomically using credit or debit operation.",
                "operationId": "3aed8fe79f35b2cd60c027d12af815cb",
                "parameters": [
                    {
                        "name": "account",
                        "in": "path",
                        "description": "Account id.",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AdjustBalanceRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Balance adjusted successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountMessageResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Account not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation or business rule error.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/statements": {
            "get": {
                "tags": [
                    "Statements"
                ],
                "summary": "Get account statement",
                "description": "Retrieves transaction history for a specific account within a date range with pagination support. Includes summary totals for debit and credit transactions.",
                "operationId": "f3d3a89fdad525e9ac50fabf65ccbfcb",
                "parameters": [
                    {
                        "name": "account_id",
                        "in": "query",
                        "description": "Account ID to retrieve statements for",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Start date for statement period (YYYY-MM-DD)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "End date for statement period (YYYY-MM-DD)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Items per page (default: 15, max: 100)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "maximum": 100,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Statement retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Transaction"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 15
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 50
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "example": 4
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "summary": {
                                            "properties": {
                                                "total_credit": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 150000
                                                },
                                                "total_debit": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 50000
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error - invalid date range or missing parameters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/statements/export": {
            "get": {
                "tags": [
                    "Statements"
                ],
                "summary": "Export account statement as CSV",
                "description": "Generates and streams a CSV file containing transaction history for a specific account within a date range. Ideal for record-keeping and external reporting with efficient streaming.",
                "operationId": "e911bd9aefb25d3a41ed7c14a7aacd5f",
                "parameters": [
                    {
                        "name": "account_id",
                        "in": "query",
                        "description": "Account ID to export statements for",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Export start date (YYYY-MM-DD)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "Export end date (YYYY-MM-DD)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "CSV file exported successfully",
                        "content": {
                            "text/csv": {
                                "schema": {
                                    "description": "CSV file with columns: transaction_date, type, amount, balance_after, description",
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error - invalid date range or missing parameters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/transactions": {
            "post": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Create transaction log",
                "description": "Records a new transaction for an account with debit or credit operation. Automatically calculates and updates balance with transaction history tracking.",
                "operationId": "ab765dced58cfe2f620929db31452145",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "account_id",
                                    "type",
                                    "amount"
                                ],
                                "properties": {
                                    "account_id": {
                                        "description": "Account ID",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "type": {
                                        "description": "Transaction type",
                                        "type": "string",
                                        "example": "credit",
                                        "enum": [
                                            "debit",
                                            "credit"
                                        ]
                                    },
                                    "amount": {
                                        "description": "Transaction amount",
                                        "type": "number",
                                        "format": "float",
                                        "example": 100000,
                                        "minimum": 0.01
                                    },
                                    "description": {
                                        "description": "Optional description",
                                        "type": "string",
                                        "example": "Payment for invoice",
                                        "nullable": true
                                    },
                                    "reference_number": {
                                        "description": "Idempotency key / external reference",
                                        "type": "string",
                                        "example": "4f0c4ae0-7b16-48d7-9488-5893710bbda8"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Transaction created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "transaction": {
                                            "$ref": "#/components/schemas/Transaction"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error or insufficient balance",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Account": {
                "required": [
                    "id",
                    "account_number",
                    "customer_name",
                    "email",
                    "status",
                    "balance"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "account_number": {
                        "type": "string",
                        "example": "ACC202604151234560001"
                    },
                    "customer_name": {
                        "type": "string",
                        "example": "Budi Santoso"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "budi@example.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "08123456789",
                        "nullable": true
                    },
                    "address": {
                        "type": "string",
                        "example": "Bandung",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "active",
                        "enum": [
                            "active",
                            "inactive",
                            "blocked"
                        ]
                    },
                    "balance": {
                        "type": "number",
                        "format": "float",
                        "example": 150000
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-15T10:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-15T10:00:00Z"
                    }
                },
                "type": "object"
            },
            "CreateAccountRequest": {
                "required": [
                    "customer_name",
                    "email"
                ],
                "properties": {
                    "customer_name": {
                        "type": "string",
                        "example": "Budi Santoso",
                        "maxLength": 100
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "budi@example.com",
                        "maxLength": 150
                    },
                    "phone": {
                        "type": "string",
                        "example": "08123456789",
                        "nullable": true,
                        "maxLength": 30
                    },
                    "address": {
                        "type": "string",
                        "example": "Bandung",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "active",
                        "enum": [
                            "active",
                            "inactive",
                            "blocked"
                        ]
                    },
                    "balance": {
                        "type": "number",
                        "format": "float",
                        "example": 100000,
                        "minimum": 0
                    }
                },
                "type": "object"
            },
            "UpdateAccountRequest": {
                "properties": {
                    "customer_name": {
                        "type": "string",
                        "example": "Budi Santoso Updated",
                        "maxLength": 100
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "budi.new@example.com",
                        "maxLength": 150
                    },
                    "phone": {
                        "type": "string",
                        "example": "0822222222",
                        "nullable": true,
                        "maxLength": 30
                    },
                    "address": {
                        "type": "string",
                        "example": "Jakarta",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "UpdateAccountStatusRequest": {
                "required": [
                    "status"
                ],
                "properties": {
                    "status": {
                        "type": "string",
                        "example": "blocked",
                        "enum": [
                            "active",
                            "inactive",
                            "blocked"
                        ]
                    }
                },
                "type": "object"
            },
            "AdjustBalanceRequest": {
                "required": [
                    "type",
                    "amount"
                ],
                "properties": {
                    "type": {
                        "type": "string",
                        "example": "credit",
                        "enum": [
                            "debit",
                            "credit"
                        ]
                    },
                    "amount": {
                        "type": "number",
                        "format": "float",
                        "example": 50000,
                        "minimum": 0.01
                    }
                },
                "type": "object"
            },
            "CreateTransactionRequest": {
                "description": "Create transaction request. Use reference_number for idempotency (same reference_number = idempotent operation).",
                "required": [
                    "account_id",
                    "type",
                    "amount"
                ],
                "properties": {
                    "account_id": {
                        "description": "Account ID (must exist)",
                        "type": "integer",
                        "example": 1
                    },
                    "type": {
                        "description": "Transaction type",
                        "type": "string",
                        "example": "credit",
                        "enum": [
                            "debit",
                            "credit"
                        ]
                    },
                    "amount": {
                        "description": "Transaction amount",
                        "type": "number",
                        "format": "float",
                        "example": 100000,
                        "minimum": 0.01
                    },
                    "description": {
                        "description": "Optional transaction description",
                        "type": "string",
                        "example": "Payment for invoice",
                        "nullable": true,
                        "maxLength": 255
                    },
                    "reference_number": {
                        "description": "Idempotency key / external reference (UUID recommended)",
                        "type": "string",
                        "example": "PAY-2026-06-03-001",
                        "nullable": true,
                        "maxLength": 191
                    }
                },
                "type": "object"
            },
            "TransactionResponse": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "transaction": {
                        "$ref": "#/components/schemas/Transaction"
                    }
                },
                "type": "object"
            },
            "ErrorMessageResponse": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": false
                    },
                    "message": {
                        "type": "string",
                        "example": "Account not found."
                    }
                },
                "type": "object"
            },
            "AccountDataResponse": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/Account"
                    }
                },
                "type": "object"
            },
            "AccountMessageResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Account updated successfully."
                    },
                    "data": {
                        "$ref": "#/components/schemas/Account"
                    }
                },
                "type": "object"
            },
            "PaginatedAccountsResponse": {
                "properties": {
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 15
                    },
                    "total": {
                        "type": "integer",
                        "example": 120
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 8
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Account"
                        }
                    }
                },
                "type": "object"
            },
            "ErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "type": "object"
            },
            "Transaction": {
                "required": [
                    "id",
                    "account_id",
                    "reference_number",
                    "type",
                    "amount",
                    "balance_before",
                    "balance_after",
                    "transaction_date"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "account_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "reference_number": {
                        "type": "string",
                        "format": "uuid",
                        "example": "550E8400-E29B-41D4-A716-446655440000"
                    },
                    "type": {
                        "type": "string",
                        "example": "credit",
                        "enum": [
                            "debit",
                            "credit"
                        ]
                    },
                    "amount": {
                        "type": "number",
                        "format": "float",
                        "example": 100000
                    },
                    "balance_before": {
                        "type": "number",
                        "format": "float",
                        "example": 0
                    },
                    "balance_after": {
                        "type": "number",
                        "format": "float",
                        "example": 100000
                    },
                    "transaction_date": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-15T10:00:00Z"
                    },
                    "description": {
                        "type": "string",
                        "example": "Transaction description",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-15T10:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-15T10:00:00Z"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Accounts",
            "description": "Account Management API"
        },
        {
            "name": "Statements",
            "description": "Statement Generator API"
        },
        {
            "name": "Transactions",
            "description": "Transaction Logging API"
        }
    ]
}